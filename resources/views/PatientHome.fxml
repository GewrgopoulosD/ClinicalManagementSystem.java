<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.PatientHomeController">

    <VBox spacing="30" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">

        <VBox spacing="5">
            <Label fx:id="welcomeLabel" text="Welcome back!" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
        </VBox>

        <HBox spacing="20">

            <VBox spacing="10" prefWidth="300"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Upcoming Appointment" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Separator/>
                <Label fx:id="nextDateLbl" text="No upcoming appointments" style="-fx-font-size: 16px;"/>
                <Label fx:id="nextDoctorLbl" text="--" style="-fx-text-fill: #3498db;"/>
            </VBox>

            <VBox spacing="10" prefWidth="300"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="History Summary" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Separator/>
                <HBox spacing="10">
                    <Label text="Total Visits:" />
                    <Label fx:id="totalVisitsLbl" text="0" style="-fx-font-weight: bold;"/>
                </HBox>
            </VBox>

        </HBox>

    </VBox>
</AnchorPane>
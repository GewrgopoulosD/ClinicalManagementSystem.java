<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox spacing="20.0"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.DoctorAppointmentsController"
      stylesheets="@../css/DoctorDashboardCss.css">

    <VBox styleClass="titleContainer">
        <Label text="Today's Appointments" styleClass="mainTitle"/>
    </VBox>

    <HBox styleClass="cards">

        <VBox fx:id="doctorsCard" styleClass="statCard">
            <Label text="Total appointments" styleClass="statLbl"/>
            <Label fx:id="totalAppsLabel" text="0" styleClass="statValue"/>
        </VBox>

        <VBox styleClass="statCard">
            <Label text="Completed" styleClass="statLbl"/>
            <Label fx:id="completedAppsLabel" text="0" styleClass="statValue"/>
        </VBox>

        <VBox styleClass="statCardLong">
            <Label text="Next appointment" styleClass="statLbl"/>
            <Label fx:id="nextAppLabel" text="--:--" styleClass="statValueLong"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <VBox styleClass="statCardTime">
            <Label fx:id="currentDateLabel" styleClass="dateTime"/>
        </VBox>
    </HBox>

    <TableView fx:id="appointmentsTable" VBox.vgrow="ALWAYS" styleClass="docTable">
        <columns>
            <TableColumn fx:id="timeColumn" prefWidth="100.0" text="Date and time " />
            <TableColumn fx:id="patientNameColumn" prefWidth="200.0" text="Patient" />
            <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Status" />
            <TableColumn fx:id="descColumn" prefWidth="300.0" text="Describe" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox spacing="15.0" alignment="CENTER_RIGHT">
        <Button fx:id="refreshBtn" text="Refresh" styleClass="refreshBtn"/>

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="cancelBtn" text="Cancel" styleClass="redBtn" />
        <Button fx:id="completeBtn" text="Complete" styleClass="greenBtn"/>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox spacing="20.0"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.DoctorAppointmentsController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox spacing="30.0" alignment="CENTER_LEFT">
        <VBox spacing="5.0" styleClass="stat-card">
            <Label text="Total appointments" styleClass="stat-header"/>
            <Label fx:id="totalAppsLabel" text="0" styleClass="stat-value" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="5.0" styleClass="stat-card">
            <Label text="Completed" styleClass="stat-header"/>
            <Label fx:id="completedAppsLabel" text="0" styleClass="stat-value" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="5.0" styleClass="stat-card">
            <Label text="Next appointment" styleClass="stat-header"/>
            <Label fx:id="nextAppLabel" text="--:--" styleClass="stat-value" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <VBox alignment="CENTER_RIGHT">
            <Label text="Day" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label fx:id="currentDateLabel"/>
        </VBox>
    </HBox>

    <TableView fx:id="appointmentsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="timeColumn" prefWidth="100.0" text="Date and time " />
            <TableColumn fx:id="patientNameColumn" prefWidth="200.0" text="Patient" />
            <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Status" />
            <TableColumn fx:id="descColumn" prefWidth="300.0" text="Describe" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox spacing="15.0" alignment="CENTER_RIGHT">
        <Button fx:id="refreshBtn" text="Refresh" />

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="cancelBtn" text="Cancel" styleClass="btn-danger" />
        <Button fx:id="completeBtn" text="Complete" styleClass="btn-success" />
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.IndexController"
            stylesheets="@/css/IndexCss.css">
    <center>
        <StackPane alignment="CENTER">
            <!-- background image -->
            <ImageView fitWidth="800" fitHeight="600">
                <Image url="@/photos/indexBack.jpg"/>
            </ImageView>

            <!-- form -->
            <VBox alignment="CENTER" spacing="10">
                <Label fx:id="WelcomeLbl" text="Welcome to Clinic"/>
                <TextField fx:id="emailTxt" promptText="Email"/>
                <PasswordField fx:id="passwordTxt" promptText="Password"/>
                <Button fx:id="loginBtn" text="Login" />
                    <HBox alignment="CENTER" spacing="10">
                        <Label fx:id="signupLbl" text="Don't have an account?"/>
                        <Button fx:id="signUpBtn" text="Sign Up" />
                    </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>

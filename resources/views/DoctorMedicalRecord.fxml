<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.DoctorMedicalRecordController" style="-fx-background-color: #f8f9fa;">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <HBox spacing="20" alignment="CENTER_LEFT">
        <children>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Ιατρικό Ιστορικό Ασθενών" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Label text="Αναζήτηση ασθενή και διαχείριση γνωματεύσεων" style="-fx-text-fill: #7f8c8d;"/>
            </VBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <TextField fx:id="patientSearchField" promptText="Αναζήτηση ΑΜΚΑ ή Επωνύμου..." prefWidth="300"
                           style="-fx-padding: 8; -fx-background-radius: 5;"/>
            </HBox>
        </children>
    </HBox>

    <SplitPane dividerPositions="0.35" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 5;">
        <items>
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <Label text="Λίστα Ασθενών" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                <TableView fx:id="patientTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="amkaCol" text="ΑΜΚΑ" prefWidth="100"/>
                        <TableColumn fx:id="lastnameCol" text="Επώνυμο" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <TabPane fx:id="detailsTabPane" tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;">
                <tabs>
                    <Tab text="Ιστορικό Επισκέψεων">
                        <VBox spacing="15">
                            <padding>
                                <Insets top="15" right="15" bottom="15" left="15"/>
                            </padding>
                            <Label text="Επιλέξτε επίσκεψη για λεπτομέρειες" style="-fx-font-weight: bold;"/>
                            <ListView fx:id="historyListView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;"/>
                        </VBox>
                    </Tab>

                    <Tab text="Γνωμάτευση Επίσκεψης">
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                            <VBox spacing="15">
                                <padding>
                                    <Insets top="20" right="20" bottom="20" left="20"/>
                                </padding>

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="Ασθενής:" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                                    <Label fx:id="lblPatientName" text="-" style="-fx-font-size: 16px; -fx-text-fill: #2980b9; -fx-font-weight: bold;"/>
                                </HBox>

                                <Separator />

                                <Label fx:id="lblAppointmentDate" text="-" style="-fx-font-style: italic; -fx-text-fill: #7f8c8d;"/>

                                <GridPane hgap="15" vgap="10">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120" prefWidth="150" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Λόγος Επίσκεψης:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                        <TextArea fx:id="txtSymptoms" editable="false" prefHeight="60" wrapText="true"
                                                  style="-fx-control-inner-background: #f1f2f6;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                        <Label text="Διάγνωση:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                        <TextArea fx:id="txtDiagnosis" prefHeight="100" wrapText="true" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                        <Label text="Θεραπεία / Αγωγή:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                        <TextArea fx:id="txtTreatment" prefHeight="100" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                        <Label text="Σημειώσεις:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                        <TextArea fx:id="txtInternalNotes" prefHeight="60" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                    </children>
                                </GridPane>

                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <Button fx:id="saveBtn" text="Αποθήκευση Γνωμάτευσης" onAction="#handleSaveRecord"
                                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5;"/>
                                </HBox>
                            </VBox>
                        </ScrollPane>
                    </Tab>
                </tabs>
            </TabPane>
        </items>
    </SplitPane>

    <HBox alignment="CENTER_LEFT" spacing="10" prefHeight="40"
          style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;">
        <padding>
            <Insets left="15" right="15"/>
        </padding>
        <Label text="Συνολικές Επισκέψεις Ασθενή:" style="-fx-font-size: 12px;"/>
        <Label fx:id="totalVisitsLbl" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
    </HBox>

</VBox>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PatientBookingController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Book New Appointment" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <HBox spacing="10.0">
        <ComboBox fx:id="specialtyCombo" promptText="Select Specialty" prefWidth="200.0" />
        <ComboBox fx:id="doctorCombo" promptText="Select Doctor" prefWidth="200.0" />
    </HBox>

    <HBox spacing="10.0">
        <DatePicker fx:id="appointmentDatePicker" promptText="Select Date" />
        <ComboBox fx:id="timeSlotsCombo" promptText="Available Hours" prefWidth="150.0" disable="true" />
    </HBox>

    <Label text="Comments / Symptoms:" />
    <TextArea fx:id="commentsArea" prefHeight="100.0" promptText="Type any details here..." />

    <Button text="Confirm Booking" onAction="#handleBooking" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />
</VBox>
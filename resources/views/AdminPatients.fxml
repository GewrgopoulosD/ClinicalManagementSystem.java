<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="patRootContainer"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../css/AdminDashboardCss.css"
      fx:controller="controllers.AdminPatientsController">

    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="patheaderBox">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Patient Management" styleClass="patMainTitle"/>
            <Label text="View and edit patient records" styleClass="patSubtitle"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <TextField fx:id="searchField" promptText="Search AMKA or Lastname..." styleClass="patSearchInput"/>
            <Button fx:id="refreshBtn" text="Refresh List" onAction="#loadPatients" styleClass="patBtnRefresh"/>
        </HBox>
    </HBox>

    <SplitPane dividerPositions="0.35" VBox.vgrow="ALWAYS" styleClass="patSplitPane">
        <items>
            <VBox styleClass="patCard">
                <Label text="Patient List" styleClass="patCardTitle"/>
                <TableView fx:id="patientTable" VBox.vgrow="ALWAYS" styleClass="patTable">
                    <columns>
                        <TableColumn fx:id="amkaCol" text="AMKA" prefWidth="100"/>
                        <TableColumn fx:id="lastnameCol" text="Lastname" prefWidth="120"/>
                        <TableColumn fx:id="nameCol" text="Firstname" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <TabPane fx:id="detailsTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="patTabPane">
                <tabs>
                    <Tab text="Patient Profile" styleClass="noFocus">
                        <VBox styleClass="patCard">

                            <Label text="Edit Personal Information" styleClass="patCardTitle"/>

                            <GridPane vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="80" prefWidth="80" />
                                    <ColumnConstraints hgrow="ALWAYS" />
                                </columnConstraints>
                                    <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="patFormLabel"/>
                                    <TextField fx:id="editNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                    <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="patFormLabel"/>
                                    <TextField fx:id="editLastnameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                    <Label text="AMKA:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="patFormLabel"/>
                                    <TextField fx:id="editAmkaField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                    <Label text="Email:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="patFormLabel"/>
                                    <TextField fx:id="editEmailField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                    <Label text="Phone:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="patFormLabel"/>
                                    <TextField fx:id="editPhoneField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            </GridPane>

                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <Button fx:id="saveBtn" text="Save Changes" onAction="#handleSave" styleClass="patBtnSave"/>
                            </HBox>

                            <Separator />

                            <VBox spacing="10" alignment="BOTTOM_LEFT" VBox.vgrow="ALWAYS">
                                <Label text="Account Actions" styleClass="patDangerLbl"/>
                                <Button fx:id="deleteBtn" text="Delete Patient Account" styleClass="patBtnDelete"/>
                            </VBox>
                        </VBox>
                    </Tab>

                    <Tab text="Appointment History" styleClass="noFocus">
                        <VBox spacing="15" styleClass="patCard">
                            <Label text="Past and Upcoming Visits" styleClass="patCardTitle"/>
                            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" styleClass="patTable">
                                <columns>
                                    <TableColumn fx:id="dateCol" text="Date" prefWidth="100"/>
                                    <TableColumn fx:id="doctorCol" text="Doctor" prefWidth="150"/>
                                    <TableColumn fx:id="statusCol" text="Status" prefWidth="100"/>
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </Tab>

                    <Tab fx:id="consultationDetailsTab" text="Medical Record" styleClass="noFocus">
                        <ScrollPane fitToWidth="true" styleClass="scrollPaneForAnyVisit">
                            <VBox styleClass="vboxScrollPaneForAnyVisit">

                                <HBox>
                                    <Label text="Doctor: " styleClass="greyLabelMedical"/>
                                    <Label fx:id="doctorNameLbl" text="-" styleClass="boldLabelMedical"/>
                                </HBox>

                                <Separator />

                                <Label fx:id="detDateLbl" text="-" styleClass="boldLabelMedical"/>

                                <GridPane styleClass="gridConsultation">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120" prefWidth="150" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>

                                    <Label text="Reason for Visit:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="boldLabelMedical"/>
                                    <TextArea fx:id="detSymptomsArea" editable="false" wrapText="true" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="gridsTxt"/>

                                    <Label text="Diagnosis:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="boldLabelMedical"/>
                                    <TextArea fx:id="detDiagnosisArea" editable="false" wrapText="true" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="gridsTxt"/>

                                    <Label text="Treatment Plan:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="boldLabelMedical"/>
                                    <TextArea fx:id="detTreatmentArea" editable="false" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="gridsTxt"/>

                                    <Label text="Internal Notes:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="boldLabelMedical"/>
                                    <TextArea fx:id="detInternalNotesArea" editable="false" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="gridsTxt"/>
                                </GridPane>
                            </VBox>
                        </ScrollPane>
                    </Tab>
                </tabs>
            </TabPane>
        </items>
    </SplitPane>

    <HBox styleClass="statCard">
        <Label text="Total Registered Patients:" styleClass="patStatLbl"/>
        <Label fx:id="totalPatientsLbl" text="0" styleClass="patStatValue"/>
    </HBox>

</VBox>
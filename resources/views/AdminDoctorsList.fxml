<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox fx:id="doctorsList" styleClass="doctorsList"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../css/AdminDashboardCss.css"
      fx:controller="controllers.AdminDoctorsListController">

    <VBox styleClass="tableContainer" HBox.hgrow="ALWAYS">

        <HBox styleClass="searchBar">
            <Label text="Search by Surname:" styleClass="boldLabel"/>
            <TextField fx:id="searchField" promptText="Enter surname..." HBox.hgrow="ALWAYS" styleClass="docSearchInput"/>
            <CheckBox fx:id="pendingOnlyCheckBox" text="Pending Specialization" styleClass="boldLabel" />
        </HBox>

        <TableView fx:id="doctorTable" VBox.vgrow="ALWAYS" styleClass="docTable">
            <columns>
                <TableColumn fx:id="nameCol" text="Name"/>
                <TableColumn fx:id="lastnameCol" text="Lastname"/>
                <TableColumn fx:id="emailCol" text="Email"/>
                <TableColumn fx:id="phoneCol" text="Phone"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

    </VBox>

    <VBox styleClass="DoctorDetails">
        <Label text="Doctor Details" styleClass="titleLabel" />

        <VBox styleClass="SelectedDoctor">
            <Label text="Selected Doctor:" styleClass="greyLabel"/>
            <Label fx:id="selectedDoctorLbl" text="Please select a doctor..." styleClass="highlighDoctor" />
        </VBox>

        <Separator />

        <VBox styleClass="listGroup">
            <Label text="Current Specializations:" styleClass="boldLabel"/>
            <ListView fx:id="currentSpecsList">
                <contextMenu>
                    <ContextMenu>
                        <items>
                            <MenuItem fx:id="deleteSpecItem"
                                      text="Remove Specialization"
                                      onAction="#handleRemoveContext"
                                      styleClass="RemoveSpec"/>
                        </items>
                    </ContextMenu>
                </contextMenu>
            </ListView>
        </VBox>

        <VBox styleClass="formGroup">
            <HBox alignment="CENTER" spacing="10">
                <Label text="Assign New Specialization" styleClass="boldLabel"/>
                <Button fx:id="AddNewSpec" text="Add new" styleClass="addNewSpec"/>
            </HBox>
            <ComboBox fx:id="specializationCombo" promptText="Select Specialization" maxWidth="Infinity"/>
            <Button fx:id="assignBtn" text="Assign" styleClass="primaryButton" maxWidth="Infinity"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <Button fx:id="refreshBtn" text="Refresh list" styleClass="secondaryButton" maxWidth="Infinity"/>
    </VBox>

</HBox>
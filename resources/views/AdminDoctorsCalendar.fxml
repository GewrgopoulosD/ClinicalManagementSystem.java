<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.AdminDoctorsCalendarController"
      stylesheets="@../css/AdminDashboardCss.css"
      spacing="20"
      styleClass="mainBackground">

    <HBox styleClass="titleContainer">
        <Label text="Hospital Schedule Overview" styleClass="mainTitle"/>
    </HBox>

    <HBox spacing="10" VBox.vgrow="ALWAYS" styleClass="calendarContainer">

        <VBox spacing="15" styleClass="card, calendarSidebar">

            <VBox spacing="5">
                <Label text="Select Doctor" styleClass="boldLabelMedical"/>
                <ComboBox fx:id="doctorSelector" styleClass="calendarPickerInput" promptText="Choose a doctor..."/>
            </VBox>

            <VBox spacing="5">
                <Label text="Select Date" styleClass="boldLabelMedical"/>
                <DatePicker fx:id="calendarPicker" styleClass="calendarPickerInput" />
            </VBox>

            <Separator styleClass="sectionSeparator"/>

            <VBox spacing="10" alignment="CENTER">
                <VBox styleClass="statCard, fullWidth">
                    <Label text="Total Appointments" styleClass="statLbl"/>
                    <Label fx:id="dayTotalLbl" text="0" styleClass="statValue"/>
                </VBox>

                <Button fx:id="todayBtn" text="Back to Today"
                        styleClass="refreshBtn, fullWidth"
                        onAction="#handleGoToToday"/>
            </VBox>
        </VBox>

        <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="card">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Daily Schedule:" styleClass="boldLabelMedical"/>
                <Label fx:id="selectedDateLbl" text="2026-04-22" styleClass="statValueLong, dateDisplayLabel"/>
            </HBox>

            <TableView fx:id="calendarTable" styleClass="docTable" VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="timeCol" text="Time" prefWidth="100" />
                    <TableColumn fx:id="patientCol" text="Patient" prefWidth="200" />
                    <TableColumn fx:id="typeCol" text="Type/Status" prefWidth="120" />
                    <TableColumn fx:id="descCol" text="Description" prefWidth="250"  />
                </columns>
            </TableView>
        </VBox>

    </HBox>
</VBox>